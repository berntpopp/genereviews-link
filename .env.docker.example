# Production Docker / Nginx Proxy Manager configuration.
# Copy to .env.docker and pass it to compose with --env-file .env.docker.

# Postgres
POSTGRES_USER=genereview
POSTGRES_PASSWORD=change-me

# Public routing
GENEREVIEW_LINK_PORT=8000
NPM_NETWORK_NAME=npm_default
CORS_ORIGINS=https://genereviews-link.genefoundry.org

# NCBI
NCBI_API_KEY=
EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Corpus bootstrap
# Leave empty to boot without a corpus bundle. Set to a release asset URL, or
# "latest" after a GitHub release bundle exists, to restore a corpus at startup.
BUNDLE_URL=
BUILD_LOCAL=false
AUTO_PULL_RELEASES=false

# Runtime
LOG_JSON=true
ENVIRONMENT=production
RATE_LIMIT_STATE_FILE=/tmp/genereview-link/rate-limit.state
