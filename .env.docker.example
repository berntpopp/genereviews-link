# Production Docker / Nginx Proxy Manager configuration.
# Copy to .env.docker and pass it to compose with --env-file .env.docker.

# Postgres
POSTGRES_USER=genereview
POSTGRES_PASSWORD=change-me

# Public routing
GENEREVIEW_LINK_PORT=8000
NPM_NETWORK_NAME=npm_default
CORS_ORIGINS=https://genereviews-link.genefoundry.org
MCP_ALLOWED_HOSTS='["localhost","127.0.0.1","::1","genereviews-link.genefoundry.org"]'
MCP_ALLOWED_ORIGINS='["https://genereviews-link.genefoundry.org"]'

# NCBI
NCBI_API_KEY=
EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Corpus bootstrap
# Production path: set BUNDLE_URL to "latest" or to a pinned GitHub Release
# asset URL. Docker downloads, verifies, and pg_restores the bundle on first
# boot when the Postgres volume has no active corpus.
#
# Convenience default after the first promoted corpus release:
# BUNDLE_URL=latest
#
# Reproducible deployments should pin a release asset URL:
# BUNDLE_URL=https://github.com/berntpopp/genereviews-link/releases/download/corpus-2026-05-12-r1/genereview-corpus-2026-05-12-r1-bge-small-en-v1.5-pg18-pgv0.8.2.tar.gz
BUNDLE_URL=latest
# Bundle authenticity is FAIL-CLOSED: a downloaded bundle is promoted only when
# an INDEPENDENT committed digest anchors it. The same-host `.sha256` sibling is
# a transport-integrity check only, never the sole authenticity gate. Anchor a
# release out-of-band with its published SHA-256:
# EXPECTED_BUNDLE_SHA256=<hex sha256 of the pinned bundle .tar.gz>
# Or knowingly accept transport-integrity-only bootstrap (e.g. an air-gapped or
# dev mirror) by opting in explicitly:
# ALLOW_UNANCHORED_BUNDLE=false
BUILD_LOCAL=false
AUTO_PULL_RELEASES=false

# Runtime
LOG_JSON=true
ENVIRONMENT=production
RATE_LIMIT_STATE_FILE=/tmp/genereview-link/rate-limit.state
