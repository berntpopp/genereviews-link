# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files to keep ruff format --check stable across platforms.
# Python tooling (ruff, mypy) and CI run on POSIX line endings; without this,
# Windows checkouts get CRLF via core.autocrlf and `make format-check` breaks.
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
