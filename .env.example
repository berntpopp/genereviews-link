# NCBI Configuration
# Get an API key from your NCBI account settings for a higher request rate.
NCBI_API_KEY=""
EUTILS_BASE_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils"

# Cache Configuration
CACHE_SIZE=512
CACHE_TTL_HOURS=24 # GeneReviews do not update frequently

# Server Configuration
LOG_LEVEL="INFO"
CORS_ORIGINS="*"
MCP_ALLOWED_HOSTS='["localhost","127.0.0.1","::1"]'
MCP_ALLOWED_ORIGINS='[]'

# Structured Logging Configuration
LOG_JSON=false  # Set to true for JSON logging in production
ENVIRONMENT="development"  # Environment name for logging context

# Multi-worker Rate Limiting (Production)
# RATE_LIMIT_STATE_FILE="/tmp/genereview-rate-limit.state"  # Uncomment for multi-worker deployments
